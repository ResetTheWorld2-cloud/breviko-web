---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  keywords?: string[];
}

const SITE = "https://breviko.de";
const SITE_NAME = "BREVIKO";
const DEFAULT_OG = "/og-image.svg";

const {
  title = "BREVIKO — Apps die sich richtig anfühlen.",
  description = "Apps, Websites & KI-Agenten aus Bad Salzuflen. Wir bauen digitale Lösungen die deinem Handwerksbetrieb oder KMU Arbeit abnehmen — statt welche zu machen. Lean UX. Direkt vom Entwickler.",
  ogImage = DEFAULT_OG,
  canonical = new URL(Astro.url.pathname, SITE).href,
  noindex = false,
  type = "website",
  publishedTime,
  modifiedTime,
  keywords = [
    "App Entwicklung Bad Salzuflen",
    "Website Erstellung Ostwestfalen",
    "KI Beratung Mittelstand",
    "iOS App Entwickler NRW",
    "Lean UX Agentur",
    "Handwerker App",
    "Digitalisierung Handwerk",
    "Excel Automatisierung",
    "ChatGPT Beratung KMU",
    "Web Development Lemgo",
    "Process Automation",
  ],
} = Astro.props;

const fullOgImage = ogImage.startsWith("http") ? ogImage : `${SITE}${ogImage}`;
const keywordsStr = keywords.join(", ");

// Schema.org JSON-LD: 4 Types kombiniert
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "@id": `${SITE}/#business`,
    name: SITE_NAME,
    legalName: "BREVIKO",
    description,
    url: SITE,
    logo: `${SITE}/favicon.svg`,
    image: fullOgImage,
    email: "hello@breviko.de",
    priceRange: "€€",
    areaServed: [
      { "@type": "Country", name: "Deutschland" },
      { "@type": "Country", name: "Österreich" },
      { "@type": "Country", name: "Schweiz" },
    ],
    address: {
      "@type": "PostalAddress",
      addressLocality: "Bad Salzuflen",
      addressRegion: "Nordrhein-Westfalen",
      postalCode: "32105",
      addressCountry: "DE",
    },
    geo: {
      "@type": "GeoCoordinates",
      latitude: 52.0857,
      longitude: 8.7444,
    },
    founder: {
      "@type": "Person",
      "@id": `${SITE}/#christian`,
      name: "Christian",
      jobTitle: "Software Engineer & KI-Berater",
      worksFor: { "@id": `${SITE}/#business` },
    },
    knowsAbout: [
      "iOS App Development",
      "SwiftUI",
      "Web Development",
      "Astro",
      "Next.js",
      "AI Agents",
      "ChatGPT",
      "Process Automation",
      "Excel & VBA",
      "Lean UX Design",
      "PyTorch",
      "CoreML",
    ],
    serviceType: [
      "App-Entwicklung",
      "Website-Erstellung",
      "KI-Beratung",
      "Excel-Automatisierung",
      "Workshop & Training",
    ],
    sameAs: ["https://breviko.de"],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${SITE}/#website`,
    url: SITE,
    name: SITE_NAME,
    description,
    publisher: { "@id": `${SITE}/#business` },
    inLanguage: "de-DE",
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${SITE}/#organization`,
    name: SITE_NAME,
    url: SITE,
    logo: {
      "@type": "ImageObject",
      url: `${SITE}/favicon.svg`,
      width: 512,
      height: 512,
    },
    contactPoint: {
      "@type": "ContactPoint",
      contactType: "customer support",
      email: "hello@breviko.de",
      availableLanguage: ["German", "English"],
      areaServed: "DACH",
    },
  },
];
---

<!doctype html>
<html lang="de" dir="ltr">
  <head>
    {/* === ESSENTIAL META === */}
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="theme-color" content="#090A0C" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#090A0C" media="(prefers-color-scheme: light)" />
    <meta name="color-scheme" content="dark" />
    <meta name="format-detection" content="telephone=no" />

    {/* === SEO META === */}
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywordsStr} />
    <meta name="author" content="Christian (BREVIKO)" />
    <meta name="publisher" content="BREVIKO" />
    <meta name="generator" content={Astro.generator} />

    {/* Robots */}
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <>
        <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
        <meta name="googlebot" content="index, follow, max-image-preview:large, max-snippet:-1" />
        <meta name="bingbot" content="index, follow" />
      </>
    )}

    {/* Canonical */}
    <link rel="canonical" href={canonical} />

    {/* === GEO META === */}
    <meta name="geo.region" content="DE-NW" />
    <meta name="geo.placename" content="Bad Salzuflen" />
    <meta name="geo.position" content="52.0857;8.7444" />
    <meta name="ICBM" content="52.0857, 8.7444" />

    {/* === OPEN GRAPH (Facebook, LinkedIn, WhatsApp, …) === */}
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {type === "article" && <meta property="article:author" content="Christian" />}
    {type === "article" && <meta property="article:publisher" content="https://breviko.de" />}

    {/* === TWITTER CARD === */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@breviko_de" />
    <meta name="twitter:creator" content="@breviko_de" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />
    <meta name="twitter:image:alt" content={title} />

    {/* === FAVICONS & APP ICONS === */}
    {/* SVG favicon works in all modern browsers (Chrome, Firefox, Safari 14+, Edge) */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#FF7950" />
    {/* TODO: Generate PNG fallbacks (16, 32, 180, 192, 512) from favicon.svg before launch */}
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="apple-mobile-web-app-title" content="BREVIKO" />
    <meta name="application-name" content="BREVIKO" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="msapplication-TileColor" content="#090A0C" />

    {/* === RESOURCE HINTS / PERFORMANCE === */}
    <link rel="dns-prefetch" href="https://breviko.de" />
    <link rel="preconnect" href="https://breviko.de" crossorigin />

    {/* Preload kritischer Body-Font — eliminiert Wait-for-CSS-then-fetch-Font Wasserfall */}
    <link rel="preload" href="/fonts/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />

    {/* === SITEMAP & RSS === */}
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="BREVIKO Blog" href="/rss.xml" />

    {/* === ALTERNATE LANGUAGES (für später, wenn EN-Version dazu kommt) === */}
    <link rel="alternate" hreflang="de" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    {/* === SCHEMA.ORG JSON-LD === */}
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body>
    {/* Skip-to-Content für Keyboard-User */}
    <a
      href="#main"
      class="absolute left-2 top-2 z-50 -translate-y-20 rounded-md bg-coral-500 px-4 py-2 text-grey-1 transition-transform focus:translate-y-0"
    >
      Zum Hauptinhalt springen
    </a>

    <slot />

    {/* Reveal-on-scroll: pure JS, no framework */}
    <script>
      const supportsIO = "IntersectionObserver" in window;
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (supportsIO && !reduce) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("revealed");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -10% 0px" }
        );

        document.querySelectorAll("[data-reveal]").forEach((el) => observer.observe(el));
      } else {
        document.querySelectorAll("[data-reveal]").forEach((el) => el.classList.add("revealed"));
      }
    </script>
  </body>
</html>
