---
const reasons = [
  {
    number: "01",
    title: "Apps die einfach funktionieren",
    description:
      "Angefangen hat alles mit einer Frage: Warum sind die meisten Apps so kompliziert? Heute bauen wir Apps die so einfach sind, dass niemand eine Anleitung braucht. 6 Stück bisher, alle laufen.",
  },
  {
    number: "02",
    title: "Websites die verkaufen",
    description:
      "Gutes Produkt, schlechte Website? Passiert leider ständig. Wir bauen moderne Webauftritte die auf jedem Gerät funktionieren — schnell, schön und mit einem klaren Ziel: dein Geschäft wachsen lassen.",
  },
  {
    number: "03",
    title: "KI die wirklich arbeitet",
    description:
      "Während andere noch überlegen ob KI relevant ist, bauen wir schon Agenten die Angebote schreiben, Daten sortieren und Kundenfragen beantworten. Nicht als Experiment — im echten Einsatz.",
  },
  {
    number: "04",
    title: "Wissen das bleibt",
    description:
      "Die beste Investition? Dein Team. Unsere Workshops machen aus deinen Mitarbeitern KI-Anwender — keine Theorie, sondern Werkzeuge die ab dem nächsten Tag in eurem Alltag laufen.",
  },
];
---

<section
  id="warum"
  class="section-padding relative overflow-hidden bg-[#111111]"
>
  {/* Background glow */}
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div
      class="absolute right-1/4 top-1/2 h-[700px] w-[700px] -translate-y-1/2 translate-x-1/2 rounded-full opacity-10 blur-[140px]"
      style="background: radial-gradient(circle, #FF7950 0%, transparent 70%);"
    />
  </div>

  <div class="container-brv relative z-10">
    {/* Header */}
    <div class="mb-20 grid gap-12 lg:grid-cols-2 lg:items-end">
      <div>
        <p data-reveal class="eyebrow mb-6">Warum BREVIKO</p>
        <h2
          data-reveal
          class="h-section text-[clamp(2.5rem,6vw,5rem)] text-white"
        >
          Alles aus einer Hand.<br />
          <span class="text-white/40">Von jemandem der<br />es selbst benutzt.</span>
        </h2>
      </div>
      <p
        data-reveal
        class="max-w-xl text-16 leading-relaxed text-white/70 md:text-18"
      >
        Keine Agentur mit 40 Leuten die sich abstimmen müssen. Sondern ein Entwickler der jeden Tag mit den neuesten Technologien arbeitet — und genau weiß was funktioniert und was nur gut klingt.
      </p>
    </div>

    {/* Reasons Grid — typografisch wie Huly, KEINE klassischen Cards */}
    <div class="grid gap-px overflow-hidden rounded-3xl border border-white/5 bg-white/5 lg:grid-cols-2">
      {reasons.map((reason, idx) => (
        <article
          data-reveal
          data-spotlight-card
          class="group relative bg-[#111111] p-10 transition-colors hover:bg-grey-2 md:p-14"
          style={`transition-delay: ${idx * 80}ms`}
        >
          <div class="relative z-[3]">
            <div class="flex items-baseline gap-6">
              <span
                class="font-title bg-gradient-to-br from-coral-300 to-coral-600 bg-clip-text text-32 font-light text-transparent transition-transform group-hover:translate-x-1"
                aria-hidden="true"
              >
                {reason.number}
              </span>
              <h3 class="font-title text-24 font-medium leading-tight tracking-tight text-white md:text-28">
                {reason.title}
              </h3>
            </div>
            <p class="mt-6 max-w-xl text-15 leading-relaxed text-white/60 md:text-16">
              {reason.description}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>

  {/* Per-card mouse tracking for spotlight effect */}
  <script>
    const warumReduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!warumReduce) {
      const section = document.querySelector("#warum");
      const cards = section?.querySelectorAll<HTMLElement>("[data-spotlight-card]") ?? [];
      cards.forEach((card) => {
        let raf = 0;
        let px = 0;
        let py = 0;
        const onMove = (e: MouseEvent) => {
          const rect = card.getBoundingClientRect();
          px = e.clientX - rect.left;
          py = e.clientY - rect.top;
          if (!raf) {
            raf = requestAnimationFrame(() => {
              card.style.setProperty("--mx", `${px}px`);
              card.style.setProperty("--my", `${py}px`);
              raf = 0;
            });
          }
        };
        const onLeave = () => {
          card.style.setProperty("--mx", "-100px");
          card.style.setProperty("--my", "-100px");
        };
        card.addEventListener("mousemove", onMove, { passive: true });
        card.addEventListener("mouseleave", onLeave, { passive: true });
      });
    }
  </script>
</section>
