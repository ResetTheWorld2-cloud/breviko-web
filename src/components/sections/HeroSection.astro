---
import GlowButton from "../ui/GlowButton.astro";
import IdentityCanvas from "../IdentityCanvas.astro";
---

<section
  id="hero"
  class="relative flex min-h-screen items-center overflow-hidden bg-grey-1 pt-28 pb-20"
>
  {/* Subtle background gradient orbs */}
  <div class="pointer-events-none absolute inset-0 -z-0" aria-hidden="true">
    <div
      class="absolute left-1/4 top-1/3 h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-20 blur-[140px]"
      style="background: radial-gradient(circle, rgba(255,121,80,0.4) 0%, rgba(255,121,80,0) 70%);"
    />
    <div
      class="absolute right-1/4 bottom-1/3 h-[600px] w-[600px] translate-x-1/2 rounded-full opacity-15 blur-[160px]"
      style="background: radial-gradient(circle, rgba(213,216,246,0.3) 0%, rgba(213,216,246,0) 70%);"
    />
  </div>

  {/* Atmospheric light beam (Huly-inspired) */}
  <div
    class="pointer-events-none absolute inset-0 -z-0 flex items-center justify-center overflow-hidden"
    aria-hidden="true"
  >
    <div class="light-beam-glow absolute" style="left: 50%; top: 30%; transform: translateX(-50%);"></div>
    <div class="light-beam absolute" style="left: 50%; top: 15%; transform: translateX(-50%);"></div>
  </div>

  {/* Subtle grid pattern */}
  <div
    class="pointer-events-none absolute inset-0 -z-0 opacity-[0.025]"
    style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 80px 80px;"
    aria-hidden="true"
  />

  <div class="container-brv relative z-10">
    <div class="grid items-center gap-12 lg:grid-cols-[1fr_1.1fr] lg:gap-16">
      {/* LEFT — Headline + CTA */}
      <div>
        {/* Eyebrow */}
        <p
          data-reveal
          class="eyebrow mb-6 flex items-center gap-3"
        >
          <span class="size-1.5 rounded-full bg-coral-500 shadow-[0_0_10px_#FF7950]"></span>
          Apps. Websites. KI. Aus Bad Salzuflen.
        </p>

        {/* Headline */}
        <h1
          data-reveal
          class="h-display text-[clamp(2.5rem,6vw,4.5rem)] font-semibold"
        >
          <span class="text-gradient-hero">Keine Zeit für<br />Papierkram?</span>
          <span class="block text-gradient-coral">Gut so.</span>
        </h1>

        {/* Subhead */}
        <p
          data-reveal
          class="mt-6 max-w-xl text-16 leading-snug text-white/80 md:text-18"
        >
          Auftragsbücher voll, gute Leute schwer zu finden, nach Feierabend noch Büro?
          Wir bauen dir digitale Lösungen die <em class="not-italic text-white">Arbeit abnehmen</em>
          statt welche zu machen.
        </p>

        {/* CTAs */}
        <div data-reveal class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
          <GlowButton href="#kontakt" variant="primary" size="lg">
            Erstgespräch — kostenlos
          </GlowButton>

          <a
            href="#leistungen"
            class="group inline-flex items-center gap-2 px-2 py-3 text-14 font-medium text-white/70 transition-colors hover:text-white"
          >
            Wie wir dir helfen
            <svg
              class="size-4 transition-transform group-hover:translate-x-1"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <path d="M3 8h10m-4-4 4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>

        {/* Trust line */}
        <div data-reveal class="mt-12 flex flex-wrap items-center gap-x-6 gap-y-3 text-12 text-white/40">
          <span class="flex items-center gap-2">
            <span class="size-1 rounded-full bg-white/40"></span>
            DSGVO-konform
          </span>
          <span class="flex items-center gap-2">
            <span class="size-1 rounded-full bg-white/40"></span>
            Antwort innerhalb 24h
          </span>
          <span class="flex items-center gap-2">
            <span class="size-1 rounded-full bg-white/40"></span>
            Kein Vertriebsgespräch
          </span>
        </div>
      </div>

      {/* RIGHT — IdentityCanvas (Spotlight Reveal) */}
      <div data-reveal class="relative aspect-[1.1] w-full">
        <IdentityCanvas />
      </div>
    </div>
  </div>

  {/* Scroll indicator */}
  <div
    class="absolute bottom-8 left-1/2 hidden -translate-x-1/2 lg:block"
    aria-hidden="true"
  >
    <div class="flex h-10 w-6 items-start justify-center rounded-full border border-white/20 p-1">
      <div class="h-2 w-1 animate-bounce rounded-full bg-white/40"></div>
    </div>
  </div>
</section>
