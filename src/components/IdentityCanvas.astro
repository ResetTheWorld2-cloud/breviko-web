<script>
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  // Touch devices: kein Hover → kein Spotlight-Tracking, kein Tilt.
  // Layer B / Cursor / Hint sind via CSS schon ausgeblendet, also auch JS deaktivieren.
  const isTouch = window.matchMedia("(pointer: coarse)").matches;
  const canvas = document.querySelector<HTMLElement>("[data-identity-canvas]");
  const rotator = document.querySelector<HTMLElement>("[data-tilt-rotator]");
  const hint = canvas?.querySelector<HTMLElement>("[data-hint]");

  // Maximum tilt angle in degrees (subtle, premium-feel)
  const MAX_TILT = 4;

  if (canvas && !reduceMotion && !isTouch) {
    let raf = 0;
    let pendingX = -300;
    let pendingY = -300;
    let pendingTiltX = 0;
    let pendingTiltY = 0;
    let firstMove = true;

    const apply = () => {
      // Spotlight position
      canvas.style.setProperty("--mx", `${pendingX}px`);
      canvas.style.setProperty("--my", `${pendingY}px`);
      // 3D tilt — apply on rotator wrapper
      if (rotator) {
        rotator.style.setProperty("--tilt-x", `${pendingTiltX}deg`);
        rotator.style.setProperty("--tilt-y", `${pendingTiltY}deg`);
      }
      raf = 0;
    };

    const updateFromCoords = (clientX: number, clientY: number) => {
      const rect = canvas.getBoundingClientRect();
      const localX = clientX - rect.left;
      const localY = clientY - rect.top;
      pendingX = localX;
      pendingY = localY;

      // Normalize cursor position to -1..1 around center
      const nx = (localX / rect.width) * 2 - 1;
      const ny = (localY / rect.height) * 2 - 1;
      // Tilt: cursor at top → rotateX positive (tile leans back)
      //       cursor at right → rotateY positive (tile leans right)
      pendingTiltX = -ny * MAX_TILT;
      pendingTiltY = nx * MAX_TILT;
    };

    const onMove = (e: MouseEvent) => {
      updateFromCoords(e.clientX, e.clientY);

      if (firstMove && hint) {
        hint.style.opacity = "0";
        firstMove = false;
      }

      if (!raf) raf = requestAnimationFrame(apply);
    };

    const onLeave = () => {
      pendingX = -500;
      pendingY = -500;
      pendingTiltX = 0;
      pendingTiltY = 0;
      if (!raf) raf = requestAnimationFrame(apply);
    };

    canvas.addEventListener("mousemove", onMove, { passive: true });
    canvas.addEventListener("mouseleave", onLeave, { passive: true });
    // Touch-Handler entfallen — auf Touch ist Layer B/Cursor/Tilt komplett deaktiviert.
  }

  // ============================================================
  // INTERAKTIVITÄT: Pause-Button Toggle (Stundenzettel)
  // Wird auf ALLEN Geräten gebraucht — Desktop Hover-Reveal UND Touch
  // (Layer A bleibt sichtbar, Buttons sind tappbar).
  // ============================================================
  const pauseButtons = document.querySelectorAll<HTMLButtonElement>("[data-pause-toggle]");
  pauseButtons.forEach((btn) => {
    let paused = false;
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();
      paused = !paused;
      btn.textContent = paused ? "▶ Weiter" : "⏸ Pause";
      btn.classList.toggle("from-green-500", paused);
      btn.classList.toggle("to-green-700", paused);
      btn.classList.toggle("from-coral-500", !paused);
      btn.classList.toggle("to-coral-700", !paused);
    });
  });
</script>

<style>
  /* ============================================================
     IDENTITY CANVAS — RESPONSIVE STRATEGY
     ============================================================
     Desktop (pointer: fine):
       - Layer A stark gedimmt
       - Layer B als Spotlight-Reveal über Cursor (clip-path circle)
       - Cursor-Glow + Hint-Label sichtbar
       - 3D-Tilt aktiv

     Touch (pointer: coarse) / Reduced-Motion:
       - Layer A leichter gedimmt — alles ist direkt lesbar
       - Layer B (Spotlight) ausgeblendet — kein Hover, kein Reveal
       - Cursor-Glow + Hint-Label ausgeblendet
       - 3D-Tilt deaktiviert (kein Mouse-Tracking → kein Sinn)
     ============================================================ */

  /* Layer A — Baseline Dimming */
  .identity-grid {
    filter: brightness(0.4) saturate(0.15);
    transition: filter 600ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Touch & reduced-motion: lighter baseline so content is readable static */
  @media (pointer: coarse), (prefers-reduced-motion: reduce) {
    .identity-grid {
      filter: brightness(0.72) saturate(0.55);
      transition: none;
    }
    /* Layer B (Spotlight reveal) ausblenden — ergibt ohne Hover keinen Sinn */
    .identity-reveal,
    .identity-cursor,
    .identity-hint {
      display: none !important;
    }
    /* Tilt-Rotator zurücksetzen — kein 3D auf Touch */
    .tilt-rotator {
      transform: none !important;
    }
  }

  /* 3D Tilt Rotator — smooth easing on transform changes
     Short duration during active hover, longer for return-to-rest. */
  .tilt-rotator {
    transition: transform 400ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  /* Excel row stagger-fill animation when revealed */
  .identity-canvas .excel-row {
    animation: excelFillIn 600ms ease-out backwards;
  }
  .identity-canvas .excel-row:nth-child(2) { animation-delay: 100ms; }
  .identity-canvas .excel-row:nth-child(3) { animation-delay: 200ms; }
  .identity-canvas .excel-row:nth-child(4) { animation-delay: 300ms; }
  .identity-canvas .excel-row:nth-child(5) { animation-delay: 400ms; }
  .identity-canvas .excel-row:nth-child(6) { animation-delay: 500ms; }

  @keyframes excelFillIn {
    from {
      opacity: 0;
      transform: translateX(-8px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .identity-canvas .excel-row {
      animation: none;
    }
  }
</style>
